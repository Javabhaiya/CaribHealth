---
import { ORG_EMAIL } from '../config.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer>
  <div class="container">
    <div class="foot-grid">
      <div class="brand-col">
        <div class="brand-row">
          <span class="foot-logo" aria-hidden="true">
            <img src={`${base}/assets/logo.webp`} width="112" height="120" alt="" />
          </span>
          <h2 class="brand-name">CaribHealth Foundation</h2>
        </div>
        <p class="brand-desc">
          A 501(c)(3) charitable organization improving access to high-quality
          medical care for underserved communities across the Caribbean.
        </p>
      </div>

      <div class="link-col">
        <h2 class="col-head">Organization</h2>
        <a href={`${base}/about`}>About</a>
        <a href={`${base}/programs`}>Programs</a>
        <a href={`${base}/board`}>Board &amp; Governance</a>
        <a href={`${base}/stories`}>Stories</a>
      </div>

      <div class="link-col">
        <h2 class="col-head">Engage</h2>
        <a href={`${base}/donate`}>Donate</a>
        <a href={`${base}/contact?reason=volunteer`}>Volunteer</a>
        <a href={`${base}/training`}>Training</a>
        <a href={`${base}/contact`}>Contact</a>
      </div>
    </div>

    <div class="foot-bottom">
      <p>
        &copy; 2026 CaribHealth Foundation, Inc. &nbsp;&middot;&nbsp; 501(c)(3)
        &nbsp;&middot;&nbsp; EIN 99-2604475 &nbsp;&middot;&nbsp; Orange, CT
      </p>
      <p><a href={`mailto:${ORG_EMAIL}`}>{ORG_EMAIL}</a></p>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--navy);
    color: rgba(255, 255, 255, 0.7);
    padding: clamp(2.75rem, 5vw, 3.5rem) 0 2rem;
    font-size: 0.85rem;
  }
  .foot-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2.5rem;
    margin-bottom: 2.5rem;
  }
  .brand-col {
    grid-column: 1 / -1;
    max-width: 340px;
  }
  .brand-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.85rem;
  }
  .foot-logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background: #fff;
    border-radius: 8px;
    padding: 2px 4px;
  }
  .foot-logo img {
    height: 58px;
    width: auto;
    display: block;
  }
  .brand-name {
    font-family: var(--serif);
    color: #fff;
    font-size: 1.05rem;
    font-weight: 600;
    margin: 0;
  }
  .brand-desc {
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.65;
    font-size: 0.85rem;
    margin: 0 0 1.25rem;
  }

  .link-col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .col-head {
    color: #fff;
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 0.5rem;
  }
  .link-col a {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    font-size: 0.85rem;
  }
  .link-col a:hover {
    color: #fff;
  }

  .foot-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .foot-bottom p {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.5);
    margin: 0;
  }
  .foot-bottom a {
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
  }
  .foot-bottom a:hover {
    color: rgba(255, 255, 255, 0.8);
  }
</style>

