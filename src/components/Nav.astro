---
import { ORG_EMAIL } from '../config.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, ''); // "/CaribHealth"
const here = Astro.url.pathname.replace(/\/$/, '') || base;

const links = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/about`, label: 'About' },
  { href: `${base}/programs`, label: 'Programs' },
  { href: `${base}/board`, label: 'Board' },
  { href: `${base}/stories`, label: 'Stories' },
  { href: `${base}/training`, label: 'Training' },
  { href: `${base}/contact`, label: 'Contact' },
];

const isActive = (href) => {
  const h = href.replace(/\/$/, '') || base;
  return h === here;
};
---

<div class="topbar">
  <span class="topbar-status">
    <span class="diamond" aria-hidden="true">&#9670;</span>
    501(c)(3) Nonprofit &nbsp;&middot;&nbsp; EIN 99-2604475<span class="topbar-extra">
    &nbsp;&middot;&nbsp; Incorporated in Connecticut, 2024</span>
  </span>
  <a href={`mailto:${ORG_EMAIL}`} class="topbar-email">{ORG_EMAIL}</a>
</div>

<header>
  <nav class="nav" aria-label="Primary">
    <a href={`${base}/`} class="wordmark" aria-label="CaribHealth Foundation — home">
      <img
        class="nav-logo"
        src={`${base}/assets/logo.webp`}
        width="112"
        height="120"
        alt=""
        aria-hidden="true"
      />
      <span class="wordmark-text">
        <span class="wordmark-name">CaribHealth Foundation</span>
      </span>
    </a>

    <button
      class="hamburger"
      id="nav-toggle"
      aria-label="Toggle navigation"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg width="26" height="26" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M3 6h18M3 12h18M3 18h18" />
      </svg>
    </button>

    <div class="nav-links">
      {
        links.map((l) => (
          <a
            href={l.href}
            class={isActive(l.href) ? 'nav-link active' : 'nav-link'}
            aria-current={isActive(l.href) ? 'page' : undefined}
          >
            {l.label}
          </a>
        ))
      }
      <a href={`${base}/donate`} class="nav-donate">Donate</a>
    </div>
  </nav>

  <div class="mobile-menu" id="mobile-menu" hidden>
    {
      links.map((l) => (
        <a
          href={l.href}
          class={isActive(l.href) ? 'mobile-link active' : 'mobile-link'}
          aria-current={isActive(l.href) ? 'page' : undefined}
        >
          {l.label}
        </a>
      ))
    }
    <a href={`${base}/donate`} class="mobile-donate">Donate</a>
  </div>
</header>

<style>
  .topbar {
    background: var(--navy);
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.78rem;
    padding: 0.55rem clamp(1rem, 4vw, 2rem);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .topbar-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .diamond {
    color: var(--gold);
  }
  .topbar a {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
  }
  .topbar a:hover {
    color: #fff;
  }

  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #fff;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 clamp(1rem, 4vw, 2rem);
    height: 74px;
  }

  .wordmark {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
  }
  .nav-logo {
    height: 66px;
    width: auto;
    flex-shrink: 0;
    display: block;
  }
  .wordmark-text {
    display: flex;
    flex-direction: column;
  }
  .wordmark-name {
    font-family: var(--serif);
    font-size: 1.18rem;
    font-weight: 600;
    color: var(--navy);
    letter-spacing: -0.01em;
    line-height: 1.05;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.1rem;
  }
  .nav-link {
    font-size: 0.875rem;
    color: var(--text-2);
    text-decoration: none;
    padding: 0.5rem 0.85rem;
    position: relative;
  }
  .nav-link:hover {
    color: var(--navy);
  }
  .nav-link.active {
    color: var(--navy);
  }
  .nav-link.active::after {
    content: '';
    position: absolute;
    left: 0.85rem;
    right: 0.85rem;
    bottom: -2px;
    height: 2px;
    background: var(--gold);
  }
  .nav-donate {
    margin-left: 0.6rem;
    background: var(--navy);
    color: #fff;
    border-radius: 3px;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.62rem 1.3rem;
    text-decoration: none;
    white-space: nowrap;
  }
  .nav-donate:hover {
    background: var(--navy-2);
  }

  .hamburger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    color: var(--navy);
  }

  .mobile-menu {
    position: sticky;
    top: 74px;
    z-index: 99;
    background: #fff;
    border-bottom: 1px solid var(--border);
    box-shadow: 0 6px 14px rgba(0, 0, 0, 0.06);
    flex-direction: column;
    padding: 0.5rem 0;
  }
  .mobile-menu:not([hidden]) {
    display: flex;
  }
  .mobile-link {
    text-align: left;
    font-size: 0.98rem;
    color: var(--text-2);
    text-decoration: none;
    padding: 0.85rem 1.5rem;
  }
  .mobile-link.active {
    color: var(--navy);
    font-weight: 600;
  }
  .mobile-donate {
    margin: 0.5rem 1.5rem 0.3rem;
    background: var(--navy);
    color: #fff;
    border-radius: 3px;
    text-align: center;
    font-size: 0.98rem;
    font-weight: 500;
    padding: 0.85rem 1.5rem;
    text-decoration: none;
  }

  @media (max-width: 820px) {
    .nav-links {
      display: none;
    }
    .hamburger {
      display: flex;
    }
  }

  /* Condense the top bar on phones: keep credibility (501c3 + EIN) on one line,
     drop the incorporation note and email (both available in the footer/contact). */
  @media (max-width: 600px) {
    .topbar {
      font-size: 0.72rem;
      padding: 0.45rem clamp(1rem, 4vw, 2rem);
      gap: 0.5rem;
    }
    .topbar-extra,
    .topbar-email {
      display: none;
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');

  if (toggle && menu) {
    const close = () => {
      menu.hidden = true;
      toggle.setAttribute('aria-expanded', 'false');
    };
    const open = () => {
      menu.hidden = false;
      toggle.setAttribute('aria-expanded', 'true');
    };

    toggle.addEventListener('click', () => {
      if (menu.hidden) open();
      else close();
    });

    // Close on any link selection
    menu.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', close);
    });

    // Close when resizing up to desktop
    const mq = window.matchMedia('(max-width: 820px)');
    const onChange = (e) => {
      if (!e.matches) close();
    };
    if (mq.addEventListener) mq.addEventListener('change', onChange);
    else mq.addListener(onChange);

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !menu.hidden) {
        close();
        toggle.focus();
      }
    });
  }
</script>
