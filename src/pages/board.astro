---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import drKetwaroo from '../assets/dr-ketwaroo.jpg';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const governance = [
  {
    title: 'Officers',
    body: 'The board elects a President, Vice President, Secretary, and Treasurer to lead day-to-day governance.',
  },
  {
    title: 'Meetings',
    body: 'Directors convene at least three times per year, with a quorum of two required to act.',
  },
  {
    title: 'Committees',
    body: 'An Executive Committee and advisory committees support specific programs and initiatives.',
  },
  {
    title: 'Oversight',
    body: 'The Treasurer maintains financial records and reports regularly to the board for review.',
  },
];
---

<Base
  title="Board & Governance"
  path="board"
  description="CaribHealth Foundation is governed by a board of three directors named in its founding charter, who set strategy, approve budgets, and oversee program performance."
>
  <div class="page-band">
    <div style="max-width:1100px;margin:0 auto;">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={`${base}/`}>Home</a><span class="sep">/</span>Board &amp; Governance
      </nav>
      <h1>Board of Directors</h1>
      <p class="intro">
        Our directors provide strategic governance and clinical oversight,
        serving voluntarily under the Foundation&rsquo;s bylaws.
      </p>
    </div>
  </div>

  <section class="container section">
    <p class="eyebrow">Leadership</p>
    <h2 class="section-title">Governance and clinical direction.</h2>
    <p class="lede">
      CaribHealth Foundation is governed by a board of three directors named in
      its founding charter, who set strategy, approve budgets, and oversee
      program performance.
    </p>
    <div class="amber-banner" style="max-width:640px;margin:0 0 3rem;">
      <span class="amber-tag">Placeholder</span>
      <span>
        Director <strong>names and roles are accurate</strong>; the biography
        text below is interim placeholder copy, pending each director&rsquo;s
        approved bio.
      </span>
    </div>

    <div class="board-grid">
      <article class="director">
        <Image
          src={drKetwaroo}
          alt="Dr. Gyanprakash Ketwaroo"
          width={136}
          height={136}
          class="avatar-img"
          loading="eager"
        />
        <div class="director-body">
          <h3>Dr. Gyanprakash Ketwaroo, MD</h3>
          <div class="role">Founder, President &amp; Chair</div>
          <p>
            Board-certified gastroenterologist whose clinical work in the region
            inspired the Foundation. Provides medical direction, leads clinical
            partnerships, and serves as the registered agent.
          </p>
          <div class="director-tag">Gastroenterology &middot; Academic Medicine</div>
        </div>
      </article>

      <article class="director">
        <div class="avatar-initials" aria-hidden="true">WP</div>
        <div class="director-body">
          <h3>Wellington Phillips</h3>
          <div class="role">Director &amp; Co-Founder</div>
          <p>
            A founding trustee of the Foundation. Contributes to strategy,
            partnership development, and oversight of program operations across
            the Caribbean.
          </p>
          <div class="director-tag">Founding Trustee</div>
        </div>
      </article>

      <article class="director">
        <div class="avatar-initials" aria-hidden="true">RD</div>
        <div class="director-body">
          <h3>Ronald Dixon</h3>
          <div class="role">Director</div>
          <p>
            Serves on the board with responsibility for governance and financial
            stewardship, helping ensure the Foundation operates in accordance
            with its 501(c)(3) obligations.
          </p>
          <div class="director-tag">Governance &amp; Stewardship</div>
        </div>
      </article>
    </div>

    <div class="govern-band">
      <p class="eyebrow" style="margin-bottom:1.5rem;">How We Govern</p>
      <div class="govern-grid">
        {
          governance.map((g) => (
            <div>
              <h3 class="govern-h">{g.title}</h3>
              <p class="govern-p">{g.body}</p>
            </div>
          ))
        }
      </div>
    </div>

    <div class="cta-panel" style="margin-top:3rem;">
      <p class="eyebrow" style="color:rgba(255,255,255,0.7);">Board Membership</p>
      <h2 class="cta-h">Interested in serving on the board?</h2>
      <p class="cta-p" style="max-width:560px;margin-bottom:1.5rem;">
        As we grow, we welcome qualified candidates with backgrounds in medicine,
        public health, finance, law, or community development. Inquiries are
        reviewed by the board.
      </p>
      <a href={`${base}/contact?reason=board`} class="btn btn-gold">Submit an Inquiry</a>
    </div>
  </section>
</Base>

<style>
  .lede {
    color: var(--text-2);
    max-width: 640px;
    line-height: 1.75;
    margin: 0 0 1.25rem;
    font-size: 1rem;
  }
  .board-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
  }
  .director {
    background: #fff;
    border: 1px solid var(--border);
    padding: 1.85rem;
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    transition: border-color 0.15s;
    border-radius: 4px;
  }
  .director:hover {
    border-color: var(--border-strong);
  }
  :global(.avatar-img) {
    width: 68px;
    height: 68px;
    border-radius: 50%;
    flex-shrink: 0;
    object-fit: cover;
    object-position: center top;
  }
  .avatar-initials {
    width: 68px;
    height: 68px;
    border-radius: 50%;
    flex-shrink: 0;
    background: #e8edf5;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--serif);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--navy);
  }
  .director-body {
    flex: 1;
    min-width: 0;
  }
  .director-body h3 {
    font-family: var(--serif);
    font-size: 1.08rem;
    font-weight: 600;
    color: var(--navy);
    margin: 0 0 0.2rem;
    line-height: 1.3;
  }
  .role {
    font-size: 0.72rem;
    color: var(--gold);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.7rem;
  }
  .director-body p {
    font-size: 0.9rem;
    color: var(--text-2);
    line-height: 1.6;
    margin: 0;
  }
  .director-tag {
    font-size: 0.78rem;
    color: var(--muted);
    margin-top: 0.5rem;
    font-style: italic;
  }

  .govern-band {
    margin-top: 3rem;
    border: 1px solid var(--border);
    background: var(--tint-2);
    border-radius: 4px;
    padding: clamp(1.75rem, 3vw, 2.5rem);
  }
  .govern-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }
  .govern-h {
    font-family: var(--serif);
    font-size: 1rem;
    color: var(--navy);
    margin: 0 0 0.4rem;
  }
  .govern-p {
    font-size: 0.88rem;
    color: var(--text-2);
    line-height: 1.6;
    margin: 0;
  }

  .cta-h {
    font-family: var(--serif);
    color: #fff;
    font-size: clamp(1.3rem, 2.2vw, 1.6rem);
    font-weight: 500;
    margin: 0 0 0.75rem;
  }
  .cta-p {
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.7;
    margin: 0;
  }
</style>
