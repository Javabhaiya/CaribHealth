---
import Base from '../layouts/Base.astro';
import { events, CATEGORIES } from '../data/events.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const statusStyle = (kind) =>
  kind === 'open' ? 'status-open' : 'status-neutral';
---

<Base
  title="Missions & Events"
  path="missions"
  description="Our calendar of clinical missions, training workshops, equipment deliveries, and fundraising events across the Caribbean. Filter by type or search to find where you can help."
>
  <div class="page-band">
    <div style="max-width:1100px;margin:0 auto;">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={`${base}/`}>Home</a><span class="sep">/</span>Missions &amp; Events
      </nav>
      <h1>Upcoming missions &amp; events</h1>
      <p class="intro">
        Our calendar of clinical missions, training workshops, equipment
        deliveries, and fundraising events. Filter by type or search to find
        where you can help.
      </p>
    </div>
  </div>

  <section class="container" style="padding:clamp(2.5rem,4vw,3.5rem) clamp(1.25rem,4vw,2rem);">
    <div class="amber-banner" style="margin:0 0 1.75rem;">
      <span class="amber-tag">Interim</span>
      <span>
        <strong>Sample schedule for layout only.</strong> These missions, dates,
        and locations are placeholders &mdash; to be replaced with the board&rsquo;s
        confirmed mission calendar.
      </span>
    </div>

    <div class="filter-row">
      <div class="chips" role="group" aria-label="Filter events by category">
        {
          CATEGORIES.map((c, i) => (
            <button
              type="button"
              class={i === 0 ? 'chip active' : 'chip'}
              data-type={c}
              aria-pressed={i === 0 ? 'true' : 'false'}
            >
              {c}
            </button>
          ))
        }
      </div>
      <div class="search-wrap">
        <svg width="17" height="17" fill="none" stroke="#9ca3af" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="M21 21l-4.3-4.3"></path>
        </svg>
        <label class="visually-hidden" for="evt-search">Search missions and locations</label>
        <input
          type="search"
          id="evt-search"
          placeholder="Search missions, locations…"
          autocomplete="off"
        />
      </div>
    </div>

    <div class="events-list" id="events-list">
      {
        events.map((ev) => (
          <article
            class="event-card"
            data-type={ev.type}
            data-search={`${ev.title} ${ev.location} ${ev.desc} ${ev.region}`.toLowerCase()}
          >
            <div class="date-badge">
              <div class="date-month">{ev.month}</div>
              <div class="date-day">{ev.day}</div>
            </div>
            <div class="event-body">
              <div class="event-meta">
                <span class="type-tag">{ev.type}</span>
                <span class={`status-pill ${statusStyle(ev.statusKind)}`}>{ev.status}</span>
              </div>
              <h2 class="event-title">{ev.title}</h2>
              <div class="event-when">
                <span>&#128197; {ev.date}</span>
                <span>&#128205; {ev.location}</span>
              </div>
              <p class="event-desc">{ev.desc}</p>
            </div>
            <div class="event-action">
              <a
                href={`${base}/contact?reason=volunteer`}
                class="btn btn-outline"
                style="font-size:0.85rem;padding:0.6rem 1.2rem;"
              >
                Get Involved
              </a>
            </div>
          </article>
        ))
      }
    </div>

    <div class="empty-state" id="empty-state" hidden>
      <p class="empty-title">No events match your filters.</p>
      <p>Try a different category or clear your search.</p>
    </div>

    <div class="closing" style="margin-top:2.5rem;">
      <div style="max-width:560px;">
        <h2 class="closing-h">Want to host or sponsor a mission?</h2>
        <p class="closing-p">
          Clinics, institutions, and donors can help us add dates to this
          calendar.
        </p>
      </div>
      <a href={`${base}/contact?reason=partnership`} class="btn btn-gold" style="white-space:nowrap;">Partner With Us</a>
    </div>
  </section>
</Base>

<style>
  .filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .chip {
    background: #fff;
    color: var(--text-2);
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    padding: 0.45rem 1.05rem;
    font-size: 0.84rem;
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
  }
  .chip.active {
    background: var(--navy);
    color: #fff;
    border-color: var(--navy);
  }

  .search-wrap {
    position: relative;
    flex: 1;
    min-width: 220px;
    max-width: 320px;
  }
  .search-wrap svg {
    position: absolute;
    left: 0.8rem;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
  }
  .search-wrap input {
    width: 100%;
    border: 1px solid var(--border-strong);
    border-radius: 3px;
    font-size: 0.9rem;
    padding: 0.65rem 0.9rem 0.65rem 2.4rem;
    background: #fff;
    color: var(--text);
    outline: none;
  }
  .search-wrap input:focus {
    border-color: var(--navy);
  }

  .events-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .event-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1.5rem;
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    flex-wrap: wrap;
    transition: border-color 0.15s;
  }
  .event-card:hover {
    border-color: var(--border-strong);
  }
  .date-badge {
    width: 64px;
    flex-shrink: 0;
    text-align: center;
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
  }
  .date-month {
    background: var(--navy);
    color: #fff;
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    padding: 0.25rem 0;
    font-weight: 600;
  }
  .date-day {
    font-family: var(--serif);
    font-size: 1.5rem;
    color: var(--navy);
    padding: 0.35rem 0;
    font-weight: 500;
  }
  .event-body {
    flex: 1;
    min-width: 200px;
  }
  .event-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
    margin-bottom: 0.5rem;
  }
  .type-tag {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--navy-ink);
    background: var(--tint);
    border: 1px solid var(--border-tint);
    border-radius: 3px;
    padding: 0.18rem 0.6rem;
    font-weight: 600;
  }
  .status-pill {
    font-size: 0.78rem;
    padding: 0.2rem 0.7rem;
    border-radius: 999px;
    font-weight: 500;
    white-space: nowrap;
  }
  .status-open {
    background: #f0f9f4;
    color: #1e6e4d;
    border: 1px solid #c5e7d3;
  }
  .status-neutral {
    background: var(--tint);
    color: var(--navy-ink);
    border: 1px solid var(--border-tint);
  }
  .event-title {
    font-family: var(--serif);
    font-size: 1.12rem;
    font-weight: 600;
    color: var(--navy);
    margin: 0 0 0.3rem;
  }
  .event-when {
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 0.6rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.1rem;
  }
  .event-desc {
    font-size: 0.9rem;
    color: var(--text-2);
    line-height: 1.6;
    margin: 0;
  }
  .event-action {
    display: flex;
    align-items: center;
  }

  .empty-state {
    text-align: center;
    padding: 3.5rem 1rem;
    border: 1px dashed var(--border-strong);
    border-radius: 4px;
    color: var(--muted);
  }
  .empty-title {
    font-size: 0.98rem;
    margin: 0 0 0.3rem;
    color: var(--text-2);
    font-weight: 500;
  }
  .empty-state p:last-child {
    font-size: 0.88rem;
    margin: 0;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .closing {
    background: var(--tint);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: clamp(1.75rem, 3vw, 2.25rem);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
  }
  .closing-h {
    font-family: var(--serif);
    color: var(--navy);
    font-size: clamp(1.2rem, 2vw, 1.45rem);
    font-weight: 500;
    margin: 0 0 0.4rem;
  }
  .closing-p {
    color: var(--text-2);
    line-height: 1.7;
    margin: 0;
    font-size: 0.95rem;
  }
</style>

<script>
  const chips = Array.from(document.querySelectorAll('.chip'));
  const cards = Array.from(document.querySelectorAll('.event-card'));
  const search = document.getElementById('evt-search');
  const emptyState = document.getElementById('empty-state');

  let activeType = 'All';

  const apply = () => {
    const q = (search.value || '').trim().toLowerCase();
    let visible = 0;
    cards.forEach((card) => {
      const typeOk = activeType === 'All' || card.dataset.type === activeType;
      const searchOk = !q || card.dataset.search.includes(q);
      const show = typeOk && searchOk;
      card.hidden = !show;
      if (show) visible++;
    });
    emptyState.hidden = visible !== 0;
  };

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      activeType = chip.dataset.type;
      chips.forEach((c) => {
        const isActive = c === chip;
        c.classList.toggle('active', isActive);
        c.setAttribute('aria-pressed', isActive ? 'true' : 'false');
      });
      apply();
    });
  });

  search.addEventListener('input', apply);
</script>
