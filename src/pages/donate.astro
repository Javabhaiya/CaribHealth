---
import Base from '../layouts/Base.astro';
import { DONATION_PROVIDER_URL } from '../config.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Zeffy has no URL amount-prefill, so we embed the donation form inline for a
// single-step give-and-pay experience. Derive the embed URL from the configured
// Zeffy donation page URL (its last path segment is the form slug).
const slug = DONATION_PROVIDER_URL.split('/').filter(Boolean).pop();
const embedUrl = `https://www.zeffy.com/embed/donation-form/${slug}`;

const moreWays = [
  {
    n: '01',
    title: 'Clinical Volunteers',
    body: 'Licensed physicians, nurses, and allied health professionals are welcomed for missions. Non-clinical roles in logistics and coordination are also available.',
    cta: 'Volunteer Inquiry',
    reason: 'volunteer',
  },
  {
    n: '02',
    title: 'Institutional Partnerships',
    body: 'We partner with hospitals, medical schools, and corporations for supply donations, training collaborations, and program funding.',
    cta: 'Partnership Inquiry',
    reason: 'partnership',
  },
  {
    n: '03',
    title: 'Spread Awareness',
    body: 'Sharing our mission with colleagues and community groups expands our base of supporters and volunteers. Request an information packet to share.',
    cta: 'Request Information Packet',
    reason: 'packet',
  },
];
---

<Base
  title="Donate"
  path="donate"
  description="Give, volunteer clinical time, or partner your institution — every form of support extends our capacity to serve patients across the Caribbean. Tax-deductible 501(c)(3)."
>
  <div class="page-band">
    <div style="max-width:1100px;margin:0 auto;">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={`${base}/`}>Home</a><span class="sep">/</span>Get Involved
      </nav>
      <h1>Get involved</h1>
      <p class="intro">
        Give, volunteer clinical time, or partner your institution &mdash; every
        form of support extends our capacity to serve patients across the
        Caribbean.
      </p>
    </div>
  </div>

  <section class="donate-section">
    <div class="donate-card">
      <div class="donate-head">
        <div>
          <div class="donate-title">Make a donation</div>
          <div class="donate-sub">Tax-deductible &middot; 501(c)(3) &middot; EIN 99-2604475</div>
        </div>
      </div>

      <div class="donate-body">
        <div class="zeffy-embed">
          <iframe
            title="CaribHealth Foundation secure donation form"
            src={embedUrl}
            allow="payment"
            loading="lazy"
          ></iframe>
        </div>
        <p class="secure-note">
          <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <rect x="3" y="11" width="18" height="11" rx="2"></rect>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
          </svg>
          Securely processed by Zeffy &mdash; a 0%-fee donation platform for nonprofits. Your gift is tax-deductible.
        </p>
      </div>
    </div>
  </section>

  <!-- More ways to help -->
  <section class="container" style="padding:clamp(1.5rem,3vw,2.5rem) clamp(1.25rem,4vw,2rem) clamp(3.5rem,6vw,5rem);">
    <p class="eyebrow" style="text-align:center;">More Ways to Help</p>
    <h2 class="section-title" style="text-align:center;margin:0 0 2.5rem;">Beyond a donation.</h2>
    <div class="ways-grid">
      {
        moreWays.map((w) => (
          <div class="way-card">
            <div class="way-num">{w.n}</div>
            <h3>{w.title}</h3>
            <p>{w.body}</p>
            <a href={`${base}/contact?reason=${w.reason}`} class="btn btn-outline" style="width:100%;font-size:0.85rem;padding:0.65rem 1.2rem;">
              {w.cta}
            </a>
          </div>
        ))
      }
    </div>
  </section>
</Base>

<style>
  .donate-section {
    max-width: 660px;
    margin: 0 auto;
    padding: clamp(3rem, 5vw, 4.5rem) clamp(1.25rem, 4vw, 2rem) clamp(2rem, 3vw, 3rem);
  }
  .donate-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 6px;
    box-shadow: 0 8px 30px rgba(10, 31, 61, 0.06);
    overflow: hidden;
  }
  .donate-head {
    background: linear-gradient(135deg, var(--navy), var(--navy-2));
    color: #fff;
    padding: 1.5rem clamp(1.5rem, 3vw, 2rem);
  }
  .donate-title {
    font-family: var(--serif);
    font-size: 1.25rem;
    font-weight: 500;
  }
  .donate-sub {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.7);
    margin-top: 0.2rem;
  }
  .donate-body {
    padding: clamp(1.5rem, 3vw, 2.25rem);
  }
  .zeffy-embed {
    width: 100%;
  }
  .zeffy-embed iframe {
    width: 100%;
    height: 560px;
    border: 0;
    border-radius: 4px;
    display: block;
  }
  @media (max-width: 600px) {
    .zeffy-embed iframe {
      height: 720px;
    }
  }

  .secure-note {
    font-size: 0.78rem;
    color: var(--muted);
    margin: 0.9rem 0 0;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
  }


  .ways-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }
  .way-card {
    background: #fff;
    border: 1px solid var(--border);
    padding: 2rem;
    transition: border-color 0.15s;
    display: flex;
    flex-direction: column;
  }
  .way-card:hover {
    border-color: var(--border-strong);
  }
  .way-num {
    font-family: var(--serif);
    color: var(--gold);
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
  }
  .way-card h3 {
    font-family: var(--serif);
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 0.75rem;
    color: var(--navy);
  }
  .way-card p {
    font-size: 0.9rem;
    color: var(--text-2);
    line-height: 1.65;
    margin: 0 0 1.5rem;
    flex: 1;
  }
</style>

